LISTEN_ADDR=127.0.0.1:8080
DATABASE_PATH=./data/situation.db

OPENROUTER_API_KEY=
OPENROUTER_MODEL=x-ai/grok-4-fast
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_JSON_OBJECT=true
OPENROUTER_HTTP_TIMEOUT_SEC=120

SWEEP_BRIEF_FILE=config/brief.txt
SWEEP_POLL_SEC=3600
SWEEP_ON_START=true

RSS_FEEDS_FILE=config/feeds.txt
RSS_POLL_SEC=900
RSS_FETCH_TIMEOUT_SEC=45
RSS_INGEST_ON_START=true

# Translation: set model to enable. Server auto-starts Ollama and pulls the model.
# Install ollama first: curl -fsSL https://ollama.com/install.sh | sh
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TRANSLATE_MODEL=gemma3:4b
TRANSLATE_TARGET_LANG=English
TRANSLATE_POLL_SEC=300
TRANSLATE_BATCH=15
TRANSLATE_ON_START=true

# Entity extraction / knowledge graph: extracts people, orgs, places, topics from items.
# Falls back to OLLAMA_TRANSLATE_MODEL if not set.
NER_MODEL=nemotron-mini
NER_POLL_SEC=900
NER_BATCH=10
NER_ON_START=true
SITUATION_MIN_ITEMS=4

# AI Briefs: uses OpenRouter if OPENROUTER_API_KEY is set, otherwise Ollama.
# BRIEF_MODEL defaults to deepseek/deepseek-chat-v3-0324 for OpenRouter.
BRIEF_MODEL=deepseek/deepseek-chat-v3-0324

MARKET_SYMBOLS=SPY,QQQ,GLD
MARKET_POLL_SEC=120
MARKET_FETCH_TIMEOUT_SEC=30
MARKET_ON_START=true

NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=
ALERT_MIN_URGENCY=4
ALERT_MAX_PER_HOUR=12
